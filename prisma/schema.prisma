generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Share {
  id        String   @id
  name      String?
  date      String
  price     String
  pe        String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShareInfo {
  id           String @id
  name         String
  stock_abbr   String
  stock_number String
  stock_pinyin String
}

model LowCodeConfig {
  id   Int    @id @default(autoincrement())
  name String @default("website")
  json String
}

model Company {
  id        String   @id @default(cuid())
  symbol    String
  market    String
  exchange  String?
  name      String
  currency  String?
  sector    String?
  industry  String?
  country   String?
  website   String?
  status    String   @default("active")
  groupId   String?  // 关联同一公司在不同市场的记录，如 "新华保险"

  // 页面展示相关字段（从 CompanyPageEntry 迁移过来）
  entryType String   @default("manual")
  entryNote String?
  sortOrder Int      @default(0)
  visible   Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  explorations CompanyExploration[]
  valuations   CompanyValuationSnapshot[]
  explanations CompanyValuationExplanation[]

  @@unique([market, symbol])
  @@index([market])
  @@index([sector])
  @@index([groupId])
  @@index([visible, sortOrder])
  @@index([entryType])
}

model CompanyExplorationRun {
  id          String    @id @default(cuid())
  name        String?
  marketScope String?
  prompt      String
  model       String?
  status      String
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  error       String?

  results CompanyExploration[]

  @@index([status, startedAt])
}

model CompanyExploration {
  id        String  @id @default(cuid())
  companyId String
  runId     String?

  title      String
  summary    String
  thesis     String?
  catalysts  String?
  risks      String?
  tags       String?
  score      Int?
  confidence Int?
  sourceUrls String?
  rawJson    String?

  visibility String   @default("draft")
  pinned     Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company Company                @relation(fields: [companyId], references: [id])
  run     CompanyExplorationRun? @relation(fields: [runId], references: [id])

  @@index([companyId, createdAt])
  @@index([visibility, pinned, createdAt])
  @@index([score])
  @@index([companyId, runId])
}

model CompanyValuationSnapshot {
  id        String   @id @default(cuid())
  companyId String
  runId     String?
  asOfDate  DateTime

  price                  Float?
  marketCap              Float?
  ttmEps                 Float?
  normalizedTtmEps       Float?
  ttmPe                  Float?
  normalizedTtmPe        Float?
  revenueTtm             Float?
  profitTtm              Float?
  normalizedProfitTtm    Float?
  profitMultiple         Int?
  referenceMultiple      Int?
  profitLinePrice        Float?
  referenceLinePrice     Float?
  upsideToProfitLine     Float?
  upsideToReferenceLine  Float?
  nonRecurringProfit     Float?
  profitQualityScore     Int?
  profitQualitySummary   String?
  source                 String?
  rawJson                String?
  createdAt              DateTime @default(now())

  company      Company                       @relation(fields: [companyId], references: [id])
  explanations CompanyValuationExplanation[]

  @@index([companyId, asOfDate])
  @@index([ttmPe])
  @@index([profitQualityScore])
  @@index([companyId, runId])
}

model CompanyValuationExplanation {
  id                  String   @id @default(cuid())
  companyId           String
  runId               String?
  valuationSnapshotId String?
  explanationType     String
  title               String
  body                String
  impactDirection     String?
  impactAmount        Float?
  isRecurring         Boolean?
  sourceUrls          String?
  confidence          Int?
  authorType          String   @default("ai")
  asOfDate            DateTime @default(now())
  isCurrent           Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  company           Company                   @relation(fields: [companyId], references: [id])
  valuationSnapshot CompanyValuationSnapshot? @relation(fields: [valuationSnapshotId], references: [id])

  @@index([companyId, explanationType, isCurrent])
  @@index([valuationSnapshotId])
  @@index([companyId, runId])
}

// CompanyPageEntry 表已废弃，字段已迁移到 Company 表
// 保留此模型定义用于历史数据迁移，迁移完成后可删除
model CompanyPageEntry {
  id        String   @id @default(cuid())
  companyId String
  entryType String
  title     String?
  note      String?
  sortOrder Int      @default(0)
  visible   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([visible, sortOrder])
  @@index([entryType])
}
